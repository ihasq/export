{
  "name": "my-export-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "cloudflare": {
    "name": "my-export-app",
    "exports": "./src"
  },
  "scripts": {
    "dev": "generate-export-types && wrangler dev",
    "deploy": "generate-export-types && wrangler deploy",
    "auth:add": "node node_modules/export-runtime/bin/auth.mjs add",
    "auth:remove": "node node_modules/export-runtime/bin/auth.mjs remove",
    "auth:list": "node node_modules/export-runtime/bin/auth.mjs list"
  },
  "dependencies": {
    "export-runtime": "^0.0.19"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
